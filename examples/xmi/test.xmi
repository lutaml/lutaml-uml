			<element xmi:idref="EAID_F432CDB8_12EE_4abd_901E_4B2138E2D7A2" xmi:type="uml:Class" name="CodeList" scope="public">
				<model package="EAPK_3C71400F_3784_4f7a_B884_573BFC270352" tpos="0" ea_localid="8" ea_eleType="element"/>
				<properties isSpecification="false" sType="Class" nType="0" scope="public" stereotype="codeList" isRoot="false" isLeaf="false" isAbstract="false" isActive="false"/>
				<project author="cportele" version="1.0" phase="1.0" created="2012-06-16 17:03:18" modified="2012-07-08 12:43:27" complexity="1" status="Proposed"/>
				<code gentype="Java"/>
				<style appearance="BackColor=-1;BorderColor=-1;BorderWidth=-1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
				<tags>
					<tag xmi:id="EAID_0BE3FA2A_659A_3065_9EA7_B5A9BCB26309" name="asDictionary" value="true#NOTES#Values: true&#xA;Default: true&#xA;Description: Encode code list as externally managed dictionary (applies to ISO 19136:2007 encoding rule). Always true in INSPIRE.&#xA;" modelElement="EAID_F432CDB8_12EE_4abd_901E_4B2138E2D7A2"/>
					<tag xmi:id="EAID_F6B0A50D_269D_2126_AF2C_CBEC3538B8AD" name="extensibility" value="any#NOTES#Values: none | narrower | any&#xA;Default: any&#xA;Description: This refers to extensions by a third party, not to extensions by the owner of the vocabulary; the owner will always be able to revise the vocabulary. I.e., if the value is 'none', the referenced vocabulary may not be extended by third parties; if the value is 'narrower', the vocabulary may be extended by narrower terms that have an existing term as a parent; if the value is 'any', the vocabulary may be extended by additional terms on any level. This value must be 'all', empty or missing, if the value 'vocabulary' is empty or missing; in this case any vocabulary may be used.&#xA;" modelElement="EAID_F432CDB8_12EE_4abd_901E_4B2138E2D7A2"/>
					<tag xmi:id="EAID_E89E2518_B746_4f80_9C3D_B91935A77D14" name="globalIdentifier" value="EAID_F432CDB8_12EE_4abd_901E_4B2138E2D7A2" modelElement="EAID_F432CDB8_12EE_4abd_901E_4B2138E2D7A2"/>
					<tag xmi:id="EAID_D435E218_4DA8_cb4d_BF4A_B108801D9ED3" name="vocabulary" value="#NOTES#Description: URI of the vocabulary/code list in the code list registry or in some external registry. The value has to be provided, if an online version of the vocabulary exists.&#xA;" modelElement="EAID_F432CDB8_12EE_4abd_901E_4B2138E2D7A2"/>
					<tag xmi:id="EAID_BCD3CBEE_B93E_edb9_B9FC_C6C82968DB8E" name="xsdEncodingRule" value="iso19136_2007#NOTES#Values: iso19136_2007 | iso19139_2007 | iso19136_2007_INSPIRE_Extensions&#xA;Default: iso19136_2007_INSPIRE_Extensions&#xA;Description: XML Schema encoding rule to apply&#xA;" modelElement="EAID_F432CDB8_12EE_4abd_901E_4B2138E2D7A2"/>
				</tags>
				<xrefs value="$XREFPROP=$XID={62F784C0-BC4E-4ed3-8B25-10BE2224727F}$XID;$NAM=Stereotypes$NAM;$TYP=element property$TYP;$VIS=Public$VIS;$PAR=0$PAR;$DES=@STEREO;Name=codeList;GUID={EFE81F55-D0F8-4530-9909-066FAD6E8C80};@ENDSTEREO;$DES;$CLT={F432CDB8-12EE-4abd-901E-4B2138E2D7A2}$CLT;$SUP=&lt;none&gt;$SUP;$ENDXREF;"/>
